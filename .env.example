# ---------------- 基础运行 ----------------
PORT=3000
NODE_ENV=production
# SQLite 文件路径（相对或绝对；前缀 file: 兼容 Prisma DSN）
DATABASE_URL=file:./data/m3u8preview.db

# 绑定地址：开发默认 0.0.0.0，生产默认 127.0.0.1（走 nginx 反代），可显式覆盖
# BIND_ADDRESS=0.0.0.0

# ---------------- 密钥（生产必须修改，>=32 字符且三者不同）----------------
JWT_SECRET=dev-jwt-secret
JWT_REFRESH_SECRET=dev-jwt-refresh-secret
PROXY_SECRET=dev-proxy-secret

# JWT 密钥轮换：新密钥改 KID 并保留旧密钥用于过渡期解码
JWT_KID=v1
# JWT_KID_PREV=v0
# JWT_SECRET_PREV=<上一代 access 密钥>
# JWT_REFRESH_SECRET_PREV=<上一代 refresh 密钥>

# ---------------- CORS ----------------
# 生产必须显式配置为前端实际地址，禁止使用 *
CORS_ORIGIN=http://localhost:5173

# ---------------- 其它 ----------------
# 是否信任 CDN 回源头（CF-Connecting-IP / True-Client-IP），默认 true
# 未部署 CDN 或未限制回源 IP 时请设为 false，防止伪造
TRUST_CDN=true

# 缩略图生成并发（1-20），默认 5
THUMBNAIL_CONCURRENCY=5

# 外部封面下载并发（1-10），默认 2
POSTER_MIGRATION_CONCURRENCY=2

# 覆盖上传/数据目录（默认是项目根下的 uploads/ 与 data/）
# UPLOADS_DIR=/app/uploads
# DATA_DIR=/data

# ---------------- 登录加密协议 ----------------
# 服务端 ECDH P-256 私钥文件；首次启动自动生成（0600）。
# 必须跨重启保持稳定，否则用户已分发的加密载荷无法解密。
# 默认 <DATA_DIR>/ecdh.pem；Docker 部署请挂载持久卷。
# ECDH_PRIVATE_KEY_PATH=/data/ecdh.pem

# ---------------- Docker / 种子账号（与 M3u8Preview_R 保持一致）----------------
# DOCKER_PORT=80
# ADMIN_SEED_PASSWORD=Admin123
# DEMO_SEED_PASSWORD=Demo1234

# ---------------- PoW 验证码（Portcullis）----------------
# 验证码服务的完整 origin，用于 CSP 白名单（允许加载外部 SDK 脚本和 WASM）。
# 其余配置（endpoint/siteKey/secretKey/开关）在管理面板中设置。
# 修改后需重启 nginx 容器生效。
# CAPTCHA_ORIGIN=https://challenge.kyxxy.com
