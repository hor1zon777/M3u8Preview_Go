# 构建产物 & 编辑器
/server
/server.exe
*.exe
*.test
*.out

# air 热重载（本机开发用）
/tmp/
build-errors.log

# 运行期数据
/data/*.db
/data/*.db-journal
/data/*.db-wal
/data/*.db-shm
# 登录加密协议 ECDH 私钥（自动生成，绝不入库）
/data/ecdh.pem
# whisper.cpp GGML 模型（数百 MB ~ GB 级，绝不入库）
/data/whisper/
/uploads/posters/*
/uploads/thumbnails/*
# 字幕 VTT 产物（运行期生成）
/uploads/subtitles/*
!/uploads/posters/.gitkeep
!/uploads/thumbnails/.gitkeep
!/uploads/subtitles/.gitkeep

# 环境变量
.env
.env.local

# IDE
.idea/
.vscode/
*.log

# 依赖
vendor/

# 前端 workspace（web/）
web/**/node_modules/
web/**/dist/
web/**/dist-image/
web/**/*.tsbuildinfo
web/.env
web/.env.local
web/.env.*.local
web/package-lock.json
# 项目用 npm workspaces；若开发期被 pnpm 操作过会留下 lockfile，忽略掉避免冲突
web/**/pnpm-lock.yaml

# claude配置
.claude
docs/AI_INTEGRATION_PROMPT.md
docs/CODE_REVIEW_2026-04-22.md
docs/VULNERABILITIES_2026-04-22.md

# Claude Code 会话日志（自动生成的临时文件，匹配命名形如 2026-MM-DD-HHMMSS-*.txt）
*-local-command-caveatcaveat-the-messages-below.txt
