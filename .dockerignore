# ========== 版本控制 / 元数据 ==========
.git
.gitignore
.github
.claude
.editorconfig

# ========== IDE ==========
.idea
.vscode
*.swp
*.swo

# ========== Go 构建产物 ==========
# 本地编译的二进制，避免污染镜像内的 /app/server
server
server.exe
*.exe
*.test
*.out
bin/
dist/
vendor/
tmp/
build-errors.log
.air.toml

# ========== 环境变量（生产通过 docker-compose environment 注入）==========
.env
.env.local
.env.*.local

# ========== 运行期数据（一律走 volume）==========
data/
uploads/

# ========== 前端本地构建产物（镜像构建阶段会 npm ci + 重新 build）==========
web/**/node_modules/
web/**/dist/
web/**/dist-image/
web/**/*.tsbuildinfo
web/.env
web/.env.local
web/.env.*.local

# ========== 日志与临时文件 ==========
*.log
tmp/

# ========== 文档（docs/PROGRESS.md 仅开发用，README 保留由 COPY . . 带入）==========
docs/

# ========== Dockerfile 自身 / compose（不打包进镜像）==========
Dockerfile
.dockerignore
docker-compose*.yml
nginx.conf
